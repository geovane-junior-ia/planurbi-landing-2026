# Normaliza fins de linha: tudo que é texto vira LF no repositório,
# independente do SO em que foi editado (evita ruído CRLF Windows <-> Mac/Linux).
* text=auto eol=lf

# Arquivos sempre binários — nunca aplicar conversão de fim de linha.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.svg   text eol=lf
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.xlsx  binary
*.zip   binary
